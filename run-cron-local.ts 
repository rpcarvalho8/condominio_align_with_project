import { runBankSync } from "./packages/web/src/api/routes/bank";

// Configuração: Definir o intervalo de tempo em horas (ex: a cada 6 horas)
const INTERVALO_EM_HORAS = 6;
const INTERVALO_EM_MS = INTERVALO_EM_HORAS * 60 * 60 * 1000;

async function executarCiclo() {
  console.log(`\n🚀 [${new Date().toISOString()}] A iniciar sincronização bancária automática...`);
  try {
    // Executa a função canónica que limpa e atribui as quotas
    await runBankSync();
  } catch (error) {
    console.error("❌ Erro crítico durante a execução do sincronismo:", error);
  }
  console.log(`😴 A aguardar ${INTERVALO_EM_HORAS} horas até ao próximo ciclo...`);
}

// Executa imediatamente ao arrancar o terminal
executarCiclo();

// Mantém o processo vivo e repete o ciclo no intervalo definido
setInterval(executarCiclo, INTERVALO_MS);
